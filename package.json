{
  "name": "simple-stripe-sdk",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Simple Stripe SDK for TypeScript",
  "homepage": "https://github.com/egorFiNE/simple-stripe-sdk#readme",
  "bugs": {
    "url": "https://github.com/egorFiNE/simple-stripe-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egorFiNE/simple-stripe-sdk.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run tests/live.stripe.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
