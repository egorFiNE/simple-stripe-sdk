{
  "name": "simple-stripe-sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "A thin zero-deps TypeScript client for the Stripe REST API",
  "keywords": [
    "stripe",
    "javascript",
    "typescript",
    "api",
    "sdk"
  ],
  "homepage": "https://github.com/egorFiNE/simple-stripe-sdk#readme",
  "author": {
    "name": "Egor Egorov",
    "email": "me@egorfine.com",
    "url": "https://egorfine.com/en/"
  },
  "bugs": {
    "url": "https://github.com/egorFiNE/simple-stripe-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egorFiNE/simple-stripe-sdk.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && cp src/form-urlencoded.mjs dist/src/",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run tests/live.stripe.test.ts",
    "lint:oxlint": "oxlint src tests",
    "lint:eslint": "eslint src",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "smoke:dist": "node --input-type=module -e \"import('./dist/src/index.js').then(() => console.log('dist import ok'))\"",
    "check": "npm run lint && npm run test && npm run build && npm run smoke:dist",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-airbnb-extended": "^3.1.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
