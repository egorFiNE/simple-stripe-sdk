{
  "name": "simple-stripe-sdk",
  "version": "0.0.1",
  "description": "Simple Stripe SDK for TypeScript",
  "homepage": "https://github.com/egorFiNE/simple-stripe-sdk#readme",
  "bugs": {
    "url": "https://github.com/egorFiNE/simple-stripe-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egorFiNE/simple-stripe-sdk.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run tests/live.stripe.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:consumer": "tsc -p tsconfig.typecheck.json --noEmit",
    "check": "bun run typecheck && bun run typecheck:consumer && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
